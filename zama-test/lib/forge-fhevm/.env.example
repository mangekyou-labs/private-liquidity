# Copy this file to .env and fill in the values when you need to override defaults.
# Remote deployments via ./deploy.sh still require these values.
# Local deployments via ./deploy-local.sh work out of the box without a .env file.

# Deployer
DEPLOYER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80 # Anvil first account

# RPC
RPC_URL=http://localhost:8545

# Gateway EIP-712 domain (use mock addresses if gateway is not deployed)
DECRYPTION_ADDRESS=0x5ffdaAB0373E62E2ea2944776209aEf29E631A64
INPUT_VERIFICATION_ADDRESS=0x812b06e1CDCE800494b79fFE4f925A504a9A9810
CHAIN_ID_GATEWAY=10901

# KMS verifier — supply address OR private key (address takes precedence)
# KMS_SIGNER_ADDRESS_0=0x
KMS_SIGNER_PRIVATE_KEY_0=0x388b7680e4e1afa06efbfd45cdd1fe39f3c6af381df6555a19661f283b97de91
PUBLIC_DECRYPTION_THRESHOLD=1

# Coprocessor / input verifier — supply address OR private key (address takes precedence)
# COPROCESSOR_SIGNER_ADDRESS_0=0x
COPROCESSOR_SIGNER_PRIVATE_KEY_0=0x7ec8ada6642fc4ccfb7729bc29c17cf8d21b61abd5642d1db992c0b8672ab901
COPROCESSOR_THRESHOLD=1

# Optional: pauser (leave unset to skip)
# PAUSER_ADDRESS_0=0x

# Optional: pass --broadcast to send live transactions, --verify to verify on Etherscan
# BROADCAST=--broadcast
# VERIFY=--verify
